NEXT_PUBLIC_APP_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Book generation runs through DeepSeek (OpenAI-compatible API).
# Without a key, api/book.py falls back to a deterministic template so the flow still works.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

AI_STRICT_MODE=false
RESEND_API_KEY=
RESEND_FROM=Personal Cosmic Book <books@example.com>

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Optional in local development. In production Vercel exposes api/chart.py at /api/chart.
CHART_API_URL=
